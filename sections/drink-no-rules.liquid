{% comment %}
  "No rules. Just sip." banner: heading plus a scrolling marquee that
  alternates colored text pills with tilted can photos.
{% endcomment %}

<script
  src="{{ 'marquee.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

<div class="drink-norules">
  <div class="drink-norules__header page-width">
    <h2 class="drink-section-heading drink-norules__heading">{{ section.settings.heading }}</h2>
    {%- if section.settings.subheading != blank -%}
      <p class="drink-norules__subheading">{{ section.settings.subheading }}</p>
    {%- endif -%}
  </div>

  <marquee-component
    class="drink-norules__marquee"
    autoplay="true"
    data-speed-factor="25"
    data-movement-direction="normal"
    style="--marquee-direction: normal;"
  >
    <div class="marquee__wrapper" ref="wrapper">
      <div class="marquee__content" ref="content">
        <div class="marquee__repeated-items" ref="marqueeItems[]">
          {%- for block in section.blocks -%}
            {%- if block.settings.content_type == 'pill' -%}
              <span class="drink-norules__pill drink-norules__pill--{{ block.settings.color }}" {{ block.shopify_attributes }}>
                {{ block.settings.text }}
              </span>
            {%- else -%}
              <span class="drink-norules__can" {{ block.shopify_attributes }}>
                {%- if block.settings.image != blank -%}
                  {{ block.settings.image | image_url: width: 200 | image_tag: class: 'drink-norules__can-img', loading: 'lazy' }}
                {%- else -%}
                  <img
                    src="{{ block.settings.fallback_asset | asset_url }}"
                    alt=""
                    class="drink-norules__can-img"
                    width="200"
                    height="250"
                    loading="lazy"
                  >
                {%- endif -%}
              </span>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    </div>
  </marquee-component>
</div>

{% stylesheet %}
  .drink-norules {
    background: #fff;
    padding-block: 56px 40px;
  }

  .drink-norules__header {
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding-block-end: 32px;
  }

  .drink-norules__heading {
    margin: 0;
    font-size: clamp(1.75rem, 3vw, 2.5rem);
  }

  .drink-norules__subheading {
    margin: 0;
    font-size: 1.35rem;
    color: var(--drink-charcoal);
  }

  .drink-norules__marquee {
    display: block;
    width: 100%;
    overflow: hidden;
  }

  .drink-norules__marquee .marquee__wrapper,
  .drink-norules__marquee .marquee__content,
  .drink-norules__marquee .marquee__repeated-items {
    display: flex;
    gap: 12px;
    width: fit-content;
    align-items: center;
  }

  .drink-norules__pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 24px;
    padding: 24px 28px;
    min-width: 180px;
    height: 129px;
    font-weight: 700;
    font-size: 1.15rem;
    text-align: center;
    color: rgba(255, 255, 255, 0.85);
    text-transform: lowercase;
  }

  .drink-norules__pill--brown {
    background: #9c7a2c;
  }

  .drink-norules__pill--teal {
    background: #4c7f8a;
  }

  .drink-norules__pill--olive {
    background: #5c6b3f;
  }

  .drink-norules__can {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 90px;
    transform: rotate(-12deg);
  }

  .drink-norules__can:nth-child(even) {
    transform: rotate(12deg);
  }

  .drink-norules__can-img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 20px;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Drink no rules",
  "tag": "section",
  "class": "section-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "No rules. Just sip."
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Drink it your way"
    }
  ],
  "blocks": [
    {
      "type": "marquee_item",
      "name": "Marquee item",
      "settings": [
        {
          "type": "select",
          "id": "content_type",
          "label": "Content type",
          "options": [
            { "value": "pill", "label": "Text pill" },
            { "value": "can", "label": "Can image" }
          ],
          "default": "pill"
        },
        {
          "type": "select",
          "id": "color",
          "label": "Pill color",
          "options": [
            { "value": "brown", "label": "Brown" },
            { "value": "teal", "label": "Teal" },
            { "value": "olive", "label": "Olive" }
          ],
          "default": "brown"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Pill text",
          "default": "you ordering or not"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Can image"
        },
        {
          "type": "text",
          "id": "fallback_asset",
          "label": "Fallback asset filename",
          "info": "Used only when no image is selected. Advanced.",
          "default": "6e-can-prithvi.png"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Drink no rules",
      "blocks": [
        { "type": "marquee_item", "settings": { "content_type": "pill", "color": "brown", "text": "you ordering or not" } },
        { "type": "marquee_item", "settings": { "content_type": "can", "fallback_asset": "6e-can-prithvi.png" } },
        { "type": "marquee_item", "settings": { "content_type": "pill", "color": "teal", "text": "in the mood or not" } },
        { "type": "marquee_item", "settings": { "content_type": "can", "fallback_asset": "6e-can-jal.png" } },
        { "type": "marquee_item", "settings": { "content_type": "pill", "color": "olive", "text": "unsure or not" } },
        { "type": "marquee_item", "settings": { "content_type": "can", "fallback_asset": "6e-can-agni.png" } },
        { "type": "marquee_item", "settings": { "content_type": "pill", "color": "olive", "text": "another round or not" } },
        { "type": "marquee_item", "settings": { "content_type": "can", "fallback_asset": "6e-can-vayu.png" } }
      ]
    }
  ]
}
{% endschema %}
