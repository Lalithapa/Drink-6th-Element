{% comment %}
  "On the #gram": heading plus a handle, followed by a row of Instagram
  photo tiles of unequal widths.
{% endcomment %}

<div class="drink-gram page-width">
  <div class="drink-gram__header">
    <h2 class="drink-section-heading drink-gram__heading">{{ section.settings.heading }}</h2>
    {%- if section.settings.handle != blank -%}
      <p class="drink-gram__handle">{{ section.settings.handle }}</p>
    {%- endif -%}
  </div>

  <div class="drink-gram__row">
    {%- for block in section.blocks -%}
      <a
        href="{{ block.settings.link | default: '#' }}"
        class="drink-gram__tile drink-gram__tile--{{ block.settings.width }}"
        {{ block.shopify_attributes }}
      >
        {%- if block.settings.image != blank -%}
          {{ block.settings.image | image_url: width: 600 | image_tag: class: 'drink-gram__img', loading: 'lazy' }}
        {%- else -%}
          <img
            src="{{ block.settings.fallback_asset | asset_url }}"
            alt=""
            class="drink-gram__img"
            width="400"
            height="423"
            loading="lazy"
          >
        {%- endif -%}
      </a>
    {%- endfor -%}
  </div>
</div>

{% stylesheet %}
  .drink-gram {
    padding-block: 56px;
  }

  .drink-gram__header {
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding-block-end: 40px;
  }

  .drink-gram__heading {
    margin: 0;
    font-size: clamp(1.75rem, 3vw, 2.5rem);
  }

  .drink-gram__handle {
    margin: 0;
    color: var(--drink-charcoal);
    font-size: 1.2rem;
  }

  .drink-gram__row {
    display: flex;
    align-items: stretch;
  }

  .drink-gram__tile {
    display: block;
    border: 1px solid #fff;
    aspect-ratio: 279 / 423;
    flex: 1 1 0;
    min-width: 0;
  }

  .drink-gram__tile--narrow {
    flex: 0.62 1 0;
  }

  .drink-gram__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @media screen and (max-width: 749px) {
    .drink-gram__row {
      flex-wrap: wrap;
    }

    .drink-gram__tile,
    .drink-gram__tile--narrow {
      flex: 1 1 40%;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Drink instagram gallery",
  "tag": "section",
  "class": "section-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "On the #gram"
    },
    {
      "type": "text",
      "id": "handle",
      "label": "Handle",
      "default": "@drinkthesixthelement"
    }
  ],
  "blocks": [
    {
      "type": "photo",
      "name": "Photo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Photo"
        },
        {
          "type": "text",
          "id": "fallback_asset",
          "label": "Fallback asset filename",
          "info": "Used only when no photo is selected. Advanced.",
          "default": "6e-gram-1.jpg"
        },
        {
          "type": "select",
          "id": "width",
          "label": "Width",
          "options": [
            { "value": "regular", "label": "Regular" },
            { "value": "narrow", "label": "Narrow" }
          ],
          "default": "regular"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Drink instagram gallery",
      "blocks": [
        { "type": "photo", "settings": { "fallback_asset": "6e-gram-1.jpg", "width": "regular" } },
        { "type": "photo", "settings": { "fallback_asset": "6e-gram-2.jpg", "width": "regular" } },
        { "type": "photo", "settings": { "fallback_asset": "6e-gram-3.jpg", "width": "regular" } },
        { "type": "photo", "settings": { "fallback_asset": "6e-gram-4.jpg", "width": "regular" } },
        { "type": "photo", "settings": { "fallback_asset": "6e-gram-5.jpg", "width": "narrow" } }
      ]
    }
  ]
}
{% endschema %}
