{% comment %}
  "The Good Stuff" transparency section: heading, CTA, and a scrollable row
  of colored pill tiles with quick trust facts.
{% endcomment %}

<div class="drink-good page-width">
  <div class="drink-good__intro">
    <h2 class="drink-section-heading drink-good__heading">{{ section.settings.heading }}</h2>
    {%- if section.settings.description != blank -%}
      <p class="drink-good__description">{{ section.settings.description }}</p>
    {%- endif -%}
    {%- if section.settings.cta_label != blank -%}
      <a href="{{ section.settings.cta_link | default: '#' }}" class="drink-pill-btn drink-pill-btn--gold">
        <span class="drink-pill-btn__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </span>
        {{ section.settings.cta_label }}
      </a>
    {%- endif -%}
  </div>

  <div class="drink-good__row">
    {%- for block in section.blocks -%}
      <div
        class="drink-good__tile drink-good__tile--{{ block.settings.color }}{% if block.settings.texture %} drink-good__tile--texture{% endif %}"
        {{ block.shopify_attributes }}
      >
        <p class="drink-good__tile-title">{{ block.settings.title }}</p>
        {%- if block.settings.body != blank -%}
          <div class="drink-good__tile-body">{{ block.settings.body }}</div>
        {%- endif -%}
        {%- if block.settings.footnote != blank -%}
          <p class="drink-good__tile-footnote">{{ block.settings.footnote }}</p>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>
</div>

{% stylesheet %}
  .drink-good {
    padding-block: 64px;
    background: #ffffff;
  }

  .drink-good__intro {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 20px;
    max-width: 680px;
    margin-inline: auto;
    padding-block-end: 40px;
  }

  .drink-good__heading {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    margin: 0;
  }

  .drink-good__description {
    margin: 0;
    color: var(--drink-ink);
    font-size: 1.05rem;
  }

  .drink-good__row {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: minmax(190px, 1fr);
    gap: 16px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    padding-block-end: 8px;
  }

  .drink-good__tile {
    scroll-snap-align: start;
    border-radius: 50px;
    padding: 40px 22px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    text-align: center;
    min-height: 232px;
    position: relative;
    overflow: hidden;
  }

  .drink-good__tile--forest {
    background: var(--drink-forest);
    color: #fffdfd;
  }

  .drink-good__tile--forest .drink-good__tile-body,
  .drink-good__tile--forest .drink-good__tile-footnote {
    color: #d1ddda;
  }

  .drink-good__tile--gold {
    background: var(--drink-gold);
    color: #ffffff;
  }

  .drink-good__tile--gold .drink-good__tile-body,
  .drink-good__tile--gold .drink-good__tile-footnote {
    color: #ffffff;
  }

  .drink-good__tile--cream {
    background: var(--drink-cream);
    color: var(--drink-sand-text);
  }

  .drink-good__tile--cream .drink-good__tile-body,
  .drink-good__tile--cream .drink-good__tile-footnote {
    color: var(--drink-sand-muted);
  }

  .drink-good__tile-title {
    margin: 0;
    font-weight: 800;
    font-size: 1.4rem;
    font-family: var(--font-body--family);
  }

  .drink-good__tile-body {
    margin: 0;
    font-size: 1rem;
    font-weight: 500;
  }

  .drink-good__tile-body ul {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .drink-good__tile-body li {
    font-size: 0.9rem;
  }

  .drink-good__tile-footnote {
    margin: 0;
    font-size: 0.75rem;
    font-style: italic;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Drink the good stuff",
  "tag": "section",
  "class": "section-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Good Stuff"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description",
      "default": "Scan the QR code on any can. See the lab report. See the farmer's name. See the GPS coordinates. Not asking you to trust us. Showing you the data."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "See How it Works"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button link"
    }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "Tile",
      "settings": [
        {
          "type": "select",
          "id": "color",
          "label": "Color",
          "options": [
            { "value": "forest", "label": "Forest green" },
            { "value": "gold", "label": "Gold" },
            { "value": "cream", "label": "Cream" }
          ],
          "default": "forest"
        },
        {
          "type": "checkbox",
          "id": "texture",
          "label": "Subtle texture background",
          "default": false
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Ultra-low calories"
        },
        {
          "type": "richtext",
          "id": "body",
          "label": "Body text",
          "default": "<p>2.5 - 30 cal</p>"
        },
        {
          "type": "text",
          "id": "footnote",
          "label": "Footnote",
          "default": "*4/5 under 15 calories"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Drink the good stuff",
      "blocks": [
        { "type": "tile", "settings": { "color": "forest", "title": "Ultra-low calories", "body": "<p>2.5 - 30 cal</p>", "footnote": "*4/5 under 15 calories" } },
        { "type": "tile", "settings": { "color": "cream", "texture": true, "title": "Zero added sugar", "body": "<p>No stevia. No artificial sweeteners</p>", "footnote": "*Monk fruit sweetened" } },
        { "type": "tile", "settings": { "color": "gold", "title": "Altitude-sourced", "body": "<p>Ingredients from 400m - 3,500m elevation across Uttarakhand</p>", "footnote": "" } },
        { "type": "tile", "settings": { "color": "cream", "texture": true, "title": "Plant based colors", "body": "<p>Blue pea flower - Blue · Anthocyanin - Pink · Turmeric - Orange</p>", "footnote": "*No synthetic dyes" } },
        { "type": "tile", "settings": { "color": "gold", "texture": true, "title": "Complete Transparency", "body": "<p>QR code links to Eurofins lab reports, farmers GPS, batch data</p>", "footnote": "" } },
        { "type": "tile", "settings": { "color": "forest", "texture": true, "title": "Vegan, gluten-free", "body": "<p>100% plant-based, gluten removed during processing</p>", "footnote": "" } }
      ]
    }
  ]
}
{% endschema %}
