{% comment %}
  Forest-green banner with a CTA button, sitting above a bright-green pill
  bar of quick trust stats (repeatable blocks).
{% endcomment %}

<div class="drink-stats">
  <div class="drink-stats__band">
    {%- if section.settings.cta_label != blank -%}
      <a
        href="{{ section.settings.cta_link | default: '#' }}"
        class="drink-pill-btn drink-pill-btn--gold"
      >
        <span class="drink-pill-btn__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </span>
        {{ section.settings.cta_label }}
      </a>
    {%- endif -%}
  </div>

  <div class="drink-stats__pill page-width">
    {%- for block in section.blocks -%}
      <div
        class="drink-stats__item"
        {{ block.shopify_attributes }}
      >
        <p class="drink-stats__number">{{ block.settings.number }}</p>
        <p class="drink-stats__label">{{ block.settings.label }}</p>
      </div>
      {%- unless forloop.last -%}
        <div class="drink-stats__divider" aria-hidden="true"></div>
      {%- endunless -%}
    {%- endfor -%}
  </div>
</div>

{% stylesheet %}
  .drink-stats {
    position: relative;
    background: var(--drink-forest);
    padding-block: 56px 0;
  }

  .drink-stats__band {
    display: flex;
    justify-content: center;
    padding-block-end: 56px;
  }

  .drink-stats__pill {
    position: relative;
    transform: translateY(50%);
    background: var(--drink-mint);
    box-shadow: 6px 6px 0.5px var(--drink-mint-shadow);
    border-radius: 50px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 24px 48px;
    padding: 30px 24px;
  }

  .drink-stats__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    text-align: center;
    color: var(--drink-forest);
    padding-inline: 12px;
  }

  .drink-stats__number {
    margin: 0;
    font-family: var(--font-body--family);
    font-weight: 800;
    font-size: clamp(1.5rem, 2.2vw, 2.1rem);
    text-transform: uppercase;
  }

  .drink-stats__label {
    margin: 0;
    font-family: var(--font-body--family);
    font-weight: 500;
    font-size: 1.1rem;
  }

  .drink-stats__divider {
    width: 1px;
    align-self: stretch;
    background: rgb(25 95 80 / 25%);
  }

  @media screen and (max-width: 749px) {
    .drink-stats__divider {
      display: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Drink stats bar",
  "tag": "section",
  "class": "section-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "See our full story"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button link"
    }
  ],
  "blocks": [
    {
      "type": "stat_item",
      "name": "Stat item",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Stat value",
          "default": "4/5 drinks"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Stat label",
          "default": "under 15 calories"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Drink stats bar",
      "blocks": [
        { "type": "stat_item", "settings": { "number": "4/5 drinks", "label": "under 15 calories" } },
        { "type": "stat_item", "settings": { "number": "'Zero'", "label": "added sugar" } },
        { "type": "stat_item", "settings": { "number": "Monkfruit", "label": "sweetened" } },
        { "type": "stat_item", "settings": { "number": "QR", "label": "traceable to farmers" } }
      ]
    }
  ]
}
{% endschema %}
