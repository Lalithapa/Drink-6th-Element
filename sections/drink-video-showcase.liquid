{% comment %}
  "See it in action": heading row plus three rounded media panels, the
  center one larger, showing the harvest-to-glass story.
{% endcomment %}

<div class="drink-video">
  <div class="drink-video__inner page-width">
    <div class="drink-video__header">
      <h2 class="drink-section-heading drink-video__heading">{{ section.settings.heading }}</h2>
      {%- if section.settings.description != blank -%}
        <p class="drink-video__description">{{ section.settings.description }}</p>
      {%- endif -%}
    </div>

    <div class="drink-video__row">
      {%- for block in section.blocks -%}
        <div class="drink-video__panel drink-video__panel--{{ block.settings.size }}" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 1000 | image_tag: class: 'drink-video__img', loading: 'lazy' }}
          {%- else -%}
            <img
              src="{{ block.settings.fallback_asset | asset_url }}"
              alt="{{ block.settings.alt }}"
              class="drink-video__img"
              width="1000"
              height="520"
              loading="lazy"
            >
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% stylesheet %}
  .drink-video {
    padding-block: 56px;
    background: var(--drink-cream);
  }

  .drink-video__header {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    justify-content: space-between;
    gap: 20px;
    padding-block-end: 40px;
  }

  .drink-video__heading {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    margin: 0;
  }

  .drink-video__description {
    max-width: 340px;
    margin: 0;
    color: var(--drink-ink);
    font-size: 1.05rem;
  }

  .drink-video__row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    overflow-x: auto;
  }

  .drink-video__panel {
    border-radius: 50px;
    overflow: hidden;
    flex-shrink: 0;
  }

  .drink-video__panel--large {
    flex: 1 1 45%;
    aspect-ratio: 991 / 508;
    max-width: 620px;
  }

  .drink-video__panel--small {
    flex: 1 1 30%;
    aspect-ratio: 919 / 464;
    max-width: 460px;
  }

  .drink-video__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @media screen and (max-width: 749px) {
    .drink-video__row {
      flex-direction: column;
    }

    .drink-video__panel--large,
    .drink-video__panel--small {
      width: 100%;
      max-width: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Drink video showcase",
  "tag": "section",
  "class": "section-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "See it in action"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description",
      "default": "From rare Himalayan ingredients to your glass, experience how every element comes together in motion"
    }
  ],
  "blocks": [
    {
      "type": "panel",
      "name": "Media panel",
      "settings": [
        {
          "type": "select",
          "id": "size",
          "label": "Size",
          "options": [
            { "value": "small", "label": "Small" },
            { "value": "large", "label": "Large (center)" }
          ],
          "default": "small"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "fallback_asset",
          "label": "Fallback asset filename",
          "info": "Used only when no image is selected. Advanced.",
          "default": "6e-video-panel-left.jpg"
        },
        {
          "type": "text",
          "id": "alt",
          "label": "Alt text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Drink video showcase",
      "blocks": [
        { "type": "panel", "settings": { "size": "small", "fallback_asset": "6e-video-panel-left.jpg", "alt": "Harvest journey" } },
        { "type": "panel", "settings": { "size": "large", "fallback_asset": "6e-video-panel-center-2.jpg", "alt": "Hand-picking sea buckthorn" } },
        { "type": "panel", "settings": { "size": "small", "fallback_asset": "6e-video-panel-right.jpg", "alt": "Canning line" } }
      ]
    }
  ]
}
{% endschema %}
